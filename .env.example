# Copy this file to .env and fill in the values before running docker compose.
# .env is never committed to git.

# MariaDB root password (used only by the db container internally)
DB_ROOT_PASSWORD=change_me_root

# Database name (default: pypki_db)
DB_NAME=pypki_db

# Application database user
DB_USER=pypki_user
DB_PASSWORD=change_me_app

# KMS encryption-at-rest KEK (Phase 0.2+). Used to derive per-provider keys
# that encrypt software private keys before they are written to KeyStorage.
# Generate a strong random value (>= 32 chars) and DO NOT rotate without
# re-encrypting existing rows.
#   openssl rand -base64 48 | tr -dc 'A-Za-z0-9_-' | head -c 64
HSM_PIN_KEK=change_me_hsm_pin_kek
