# Copy this file to .env and fill in the values before running docker compose.
# .env is never committed to git.

# MariaDB root password (used only by the db container internally)
DB_ROOT_PASSWORD=change_me_root

# Database name (default: pypki_db)
DB_NAME=pypki_db

# Application database user
DB_USER=pypki_user
DB_PASSWORD=change_me_app

# Encryption key for HSM secrets
HSM_PIN_KEK=8QyU8W4mwfB8X1I5tgGMelrZOv30ZoMxVx9gRJkv2KyMgw0XyTNjc3uKhabI
